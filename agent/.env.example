# API Keys (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# LLM Settings
LLM_PROVIDER=openai          # or "anthropic"
LLM_MODEL=gpt-4o-mini        # or "claude-3-5-sonnet-20241022"
EMBEDDING_MODEL=text-embedding-3-small
TEMPERATURE=0.3
MAX_TOKENS=1000

# RAG Settings
RETRIEVAL_K=5                # Number of docs to retrieve
SIMILARITY_THRESHOLD=0.7     # Min similarity score

# MetaShip API (for tools - optional)
METASHIP_API_URL=https://api.metaship.ru
METASHIP_API_TOKEN=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
